{
  "name": "prowlrbot-console",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:prod": "tsc -b && vite build --mode production",
    "build:test": "tsc -b && vite build --mode test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "preview:test": "vite preview --mode test"
  },
  "dependencies": {
    "@clerk/react": "^6.1.0",
    "@ant-design/x-markdown": "^2.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@prowlrbot/chat": "github:ProwlrBot/prowlr-chat#6bf695720fdb28a4030ba77e7ba490c5defcf82e",
    "@sentry/react": "^10.43.0",
    "ahooks": "^3.9.6",
    "antd": "^5.29.1",
    "antd-style": "^3.7.1",
    "i18next": "^25.8.4",
    "lucide-react": "^0.562.0",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0",
    "@xterm/xterm": "^6.0.0",
    "@xterm/addon-fit": "^0.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/i18next": "^12.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.0.0",
    "less": "^4.6.4",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5"
  },
  "overrides": {
    "dompurify": ">=3.3.2",
    "prismjs": ">=1.30.0"
  },
  "repository": "https://github.com/prowlrbot/prowlrbot.git"
