# docker/.env.example
# Copy to .env and customize before running docker compose.
#
# SECURITY: Never commit the .env file — it contains secrets.

# Shared secret for HMAC authentication between bridge and workers.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
HUB_SECRET=change-me-to-a-strong-random-string

# Host port the bridge listens on (container always uses 8099 internally)
BRIDGE_PORT=8099

# Number of worker replicas to start
WORKER_COUNT=2
