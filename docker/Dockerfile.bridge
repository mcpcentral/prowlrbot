# docker/Dockerfile.bridge
# ProwlrHub HTTP Bridge — cross-machine war room coordination
#
# Runs the bridge server that exposes the WarRoom engine over HTTP
# so remote Claude Code terminals (and swarm workers) can participate.
#
# Build context must be the repo root:
#   docker build -f docker/Dockerfile.bridge -t prowlrbot-bridge .

# ---------------------------------------------------------------------------
# Stage 1: Builder — install dependencies in a virtual-env
# ---------------------------------------------------------------------------
FROM python:3.12-slim AS builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy only dependency metadata first (cache layer)
COPY pyproject.toml .

# Copy source tree
COPY src/ src/

# Install into a virtual-env so the runtime image stays small
RUN python -m venv /opt/venv && \
    /opt/venv/bin/pip install --no-cache-dir --upgrade pip setuptools wheel && \
    /opt/venv/bin/pip install --no-cache-dir -e .

# ---------------------------------------------------------------------------
# Stage 2: Runtime — minimal image with only what we need
# ---------------------------------------------------------------------------
FROM python:3.12-slim AS runtime

# Security: run as non-root
RUN groupadd --gid 1000 prowlr && \
    useradd --uid 1000 --gid prowlr --shell /bin/bash --create-home prowlr

# Install curl for healthcheck
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

# Copy virtual-env from builder
COPY --from=builder /opt/venv /opt/venv

# Copy source (needed because we did editable install)
WORKDIR /app
COPY --from=builder /build/pyproject.toml .
COPY --from=builder /build/src/ src/

# Make sure the venv is on PATH
ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Bridge defaults — overridable via docker-compose environment
ENV PROWLR_BRIDGE_HOST=0.0.0.0 \
    PROWLR_BRIDGE_PORT=8099

# Data directory for SQLite (mounted as volume)
RUN mkdir -p /data && chown prowlr:prowlr /data
VOLUME ["/data"]

EXPOSE 8099

USER prowlr

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8099/health || exit 1

CMD ["python", "-m", "prowlrbot.hub.bridge"]
