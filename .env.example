# ProwlrBot — env example
#
# Where this file belongs:
#   Copy to .env in the PROJECT ROOT (same directory as this file and pyproject.toml).
#   .env is gitignored. Do not commit it.
#
# When it is loaded:
#   - prowlr app        loads .env from the current working directory (run from project root).
#   - prowlr set-admin-password  same; run from project root so it finds .env.
#
# --- Console / app login (first user) ---
# If you get 401 Invalid credentials, run from project root: prowlr set-admin-password
PROWLRBOT_ADMIN_USERNAME=admin
PROWLRBOT_ADMIN_PASSWORD=

# --- War Room bridge (optional; for multi-terminal coordination) ---
# PROWLR_HUB_URL=http://localhost:8099
# PROWLR_HUB_SECRET=
# PROWLR_BRIDGE_HOST=127.0.0.1
# PROWLR_BRIDGE_PORT=8099

# --- Working dir (default ~/.prowlrbot) ---
# PROWLRBOT_WORKING_DIR=~/.prowlrbot

# --- API token (optional; enable token auth for API/WebSocket) ---
# PROWLRBOT_API_TOKEN_HASH=

# --- Clerk (one auth for website + console + backend) ---
# When set, the API accepts Clerk JWTs; console and website use the same Clerk app.
# JWKS URL: in Clerk Dashboard → API Keys, or use Frontend API URL + /.well-known/jwks.json
# Example: https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_JWKS_URL=
# Optional: comma-separated allowed origins for azp claim (e.g. https://app.prowlrbot.com,https://prowlrbot.com)
# CLERK_AUTHORIZED_PARTIES=

# --- Canonical app URL (Stripe/OAuth redirects) ---
# When set, Stripe success/cancel and OAuth callbacks use this URL instead of request host.
# On Fly with custom domain, set to https://app.prowlrbot.com so redirects go to app, not prowlrbot.fly.dev.
# PROWLRBOT_BASE_URL=https://app.prowlrbot.com

# --- CORS (if console/demo is on another origin) ---
# PROWLRBOT_CORS_ORIGINS=http://localhost:5173,https://prowlrbot.com
# On the official hosted app (app.prowlrbot.com), PROWLR_OFFICIAL_APP=1 enables CORS for prowlrbot.com so the ROAR demo works.

# --- Log level: debug, info, warning, error ---
# PROWLRBOT_LOG_LEVEL=info


# --- Stripe (tiers, credits, checkout) ---
# Required for paid upgrades from Console → Credits → Upgrade.
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook: add endpoint in Dashboard → Webhooks → URL: https://YOUR_APP_URL/api/marketplace/webhook/stripe
# Events: checkout.session.completed, customer.subscription.created, invoice.payment_succeeded
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- LLM keys (set via prowlr env set or here) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
